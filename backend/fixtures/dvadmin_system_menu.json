{
  "table_name": "dvadmin_system_menu",
  "create_table_sql": "CREATE TABLE `dvadmin_system_menu` (\n  `id` bigint NOT NULL AUTO_INCREMENT COMMENT 'Id',\n  `description` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '描述',\n  `modifier` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '修改人',\n  `dept_belong_id` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '数据归属部门',\n  `update_datetime` datetime(6) DEFAULT NULL COMMENT '修改时间',\n  `create_datetime` datetime(6) DEFAULT NULL COMMENT '创建时间',\n  `icon` varchar(64) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '菜单图标',\n  `name` varchar(64) COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '菜单名称',\n  `sort` int DEFAULT NULL COMMENT '显示排序',\n  `is_link` tinyint(1) NOT NULL COMMENT '是否外链',\n  `is_catalog` tinyint(1) NOT NULL COMMENT '是否目录',\n  `web_path` varchar(128) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '路由地址',\n  `component` varchar(128) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '组件地址',\n  `component_name` varchar(50) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '组件名称',\n  `status` tinyint(1) NOT NULL COMMENT '菜单状态',\n  `frame_out` tinyint(1) NOT NULL COMMENT '是否主框架外',\n  `cache` tinyint(1) NOT NULL COMMENT '是否页面缓存',\n  `visible` tinyint(1) NOT NULL COMMENT '侧边栏中是否显示',\n  `creator_id` bigint DEFAULT NULL COMMENT '创建人',\n  `parent_id` bigint DEFAULT NULL COMMENT '上级菜单',\n  PRIMARY KEY (`id`),\n  KEY `dvadmin_system_menu_creator_id_430cdc1c` (`creator_id`),\n  KEY `dvadmin_system_menu_parent_id_bc6f21bc` (`parent_id`)\n) ENGINE=InnoDB AUTO_INCREMENT=22 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='菜单表'",
